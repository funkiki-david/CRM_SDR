# === SDR ProCRM Production Environment Variables ===
# Set these in Railway's dashboard under Variables

# Supabase PostgreSQL connection string (get from Supabase dashboard → Settings → Database)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Upstash Redis (get from Upstash dashboard)
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# JWT secret (generate a random string: openssl rand -hex 32)
SECRET_KEY=generate-a-random-64-char-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Apollo.io (optional — can also set via Settings page)
# APOLLO_API_KEY=

# Anthropic Claude (optional — can also set via Settings page)
# ANTHROPIC_API_KEY=

# OpenAI (optional — can also set via Settings page)
# OPENAI_API_KEY=

# Frontend URL (for CORS — set to your Vercel domain)
FRONTEND_URL=https://crm.amazonsolutions.us
