# === SDR CRM Production Environment Variables ===
# Set these in Railway's dashboard under Variables
#
# Railway 的 Postgres 插件暴露的原生 DATABASE_URL 是 postgresql://... 格式。
# 代码会自动把 postgresql:// → postgresql+asyncpg://（config.py validator），
# 所以你可以直接把 Railway 的 ${{ Postgres.DATABASE_URL }} 引用进来不用改。

DATABASE_URL=postgresql://user:password@host:5432/dbname
# 或直接用 Railway 的变量引用: ${{ Postgres.DATABASE_URL }}

# Redis (Railway 插件或 Upstash)
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# JWT secret — 生成：openssl rand -hex 32
# 注意：SECRET_KEY 还被用来派生 Fernet 加密密钥（SMTP 密码加密）。
# 部署后如果换这个值，所有已存储的 SMTP 密码会解密失败，需要重新输入。
SECRET_KEY=generate-a-random-64-char-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Contact database (Apollo.io) — 可走 Settings UI 运行时设置，也可走 env
APOLLO_API_KEY=

# Anthropic Claude — 同上
ANTHROPIC_API_KEY=

# OpenAI (当前未启用 — embedding search 暂停)
# OPENAI_API_KEY=

# === 可选 ===
# Frontend URL — 额外追加到 CORS 白名单（Railway 前端域名已硬编码进 main.py）
# FRONTEND_URL=https://crm.amazonsolutions.us

# Email encryption key — 用于 Fernet 加密 SMTP 密码的独立密钥。
# 不设则从 SECRET_KEY 派生。生产建议设一个独立的 32-byte urlsafe-base64 key：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# EMAIL_ENCRYPTION_KEY=
