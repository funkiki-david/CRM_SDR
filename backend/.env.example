# === SDR ProCRM 环境变量模板 ===
# 复制为 .env 后填入真实值

# 数据库连接（Docker 本地开发用）
DATABASE_URL=postgresql+asyncpg://sdrcrm:sdrcrm_dev@localhost:5432/sdrcrm

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（用于用户登录 token，请换成随机字符串）
SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Apollo.io API（后续步骤填入）
# APOLLO_API_KEY=

# Claude API（后续步骤填入）
# ANTHROPIC_API_KEY=

# OpenAI API — Embedding + Whisper（后续步骤填入）
# OPENAI_API_KEY=
